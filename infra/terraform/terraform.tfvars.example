# Copy this file to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars with real secrets to version control

aws_region   = "us-east-1"
project_name = "feature-flags"
environment  = "production"

# Networking
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b"]

# EKS
eks_cluster_name    = "eksc-challenge-fiap"
eks_cluster_version = "1.30"
node_instance_type  = "t3.medium"
node_min_size       = 1
node_max_size       = 4
node_desired_size   = 2

# RDS
db_instance_class     = "db.t3.micro"
db_engine_version     = "15.4"
auth_db_password      = "CHANGE_ME_auth_password"
flags_db_password     = "CHANGE_ME_flags_password"
targeting_db_password = "CHANGE_ME_targeting_password"

# ElastiCache
redis_node_type = "cache.t3.medium"

# SQS
sqs_queue_name = "evaluation-service-sqs"

# DynamoDB
dynamodb_table_name = "feature-flags-analytics-events"

# ECR
ecr_image_tag_mutability = "MUTABLE"
ecr_scan_on_push         = true
